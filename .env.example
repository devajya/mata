# ─── Backend (Railway) ───────────────────────────────────────────────────────
# AGENT-CTX: Google AI Studio API key for Gemini Flash classification.
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# AGENT-CTX: Optional NCBI key. Without it: 3 req/s. With it: 10 req/s.
# Get from: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here

# AGENT-CTX: Comma-separated allowed CORS origins. Set to Vercel URL in prod.
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend (Vercel) ───────────────────────────────────────────────────────
# AGENT-CTX: Must be set to Railway backend URL before Vercel build.
# Prefix NEXT_PUBLIC_ required — Next.js only exposes env vars with this prefix to the browser.
# Do NOT expose GOOGLE_API_KEY or NCBI_API_KEY here (server-side only).
NEXT_PUBLIC_API_URL=http://localhost:8000
