# Environment — NEVER commit real keys
.env
.env.local
.env.*.local
.env.example
# .env.e2e is intentionally NOT listed here — it contains only public deployment
# URLs and no secrets, so it is safe (and expected) to commit.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv/
dist/
build/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# SQLite databases (job state — never commit, regenerated on startup)
*.db
*.db-wal
*.db-shm

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Session summaries (internal dev docs, not for repo)
session_summaries/
ONBOARDING.md
Overall phases.txt
